# Neon serverless Postgres connection string (HTTP driver)
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Better Auth — generate with: bun -e "console.log(crypto.getRandomValues(new Uint8Array(32)).toBase64())"
BETTER_AUTH_SECRET=
# Base URL of the app (no trailing slash)
BETTER_AUTH_URL=http://localhost:3000

# AES-256-GCM key for encrypting provider API keys at rest — 32 bytes, base64
# Generate with: bun -e "console.log(crypto.getRandomValues(new Uint8Array(32)).toBase64())"
APP_ENCRYPTION_KEY=

# Optional: seed admin credentials (used by `bun run seed:user`)
SEED_ADMIN_EMAIL=
SEED_ADMIN_NAME=
SEED_ADMIN_PASSWORD=

# Inngest — local dev: set INNGEST_DEV=1 (SDK v4 defaults to cloud mode), no keys needed
INNGEST_DEV=1
# Production (Inngest Cloud): from the Inngest dashboard — leave empty locally
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ZenRows scraper proxy configuration (optional, required for twkan.com / biquge.tw anti-bot bypass)
SCRAPER_API_KEY=
SCRAPER_BASE=https://api.zenrows.com/v1/
SCRAPER_RENDER_JS=false
SCRAPER_PREMIUM_PROXY=true

# Optional: PostHog analytics (only active in production builds)
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com